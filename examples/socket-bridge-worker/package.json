{
  "name": "socket-bridge-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -lc 'test -f .dev.vars || { echo \"error: missing .dev.vars\" >&2; exit 1; }; exec vite dev --host 127.0.0.1 --port 5173 --strictPort'",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "agents": "^0.0.97",
    "gramjs-statemachine": "workspace:*",
    "shared-statemachine": "workspace:*",
    "zca-js-statemachine": "workspace:*",
    "zca-js": "2.1.1",
    "big-integer": "^1.6.52",
    "telegram": "2.26.22",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "qrcode": "^1.5.4",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
    "@cloudflare/workers-types": "^4.20260305.0",
    "@tailwindcss/postcss": "^4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-rsc": "^0.5.21",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vinext": "^0.0.11",
    "vite": "^7.3.1",
    "wrangler": "^4.68.1"
  }
}
