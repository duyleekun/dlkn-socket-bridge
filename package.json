{
  "name": "dlkn-socket-bridge-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "dev:bridge": "pnpm --stream --filter dlkn-socket-bridge-rs run dev",
    "dev:telegram": "pnpm --parallel --stream --filter dlkn-socket-bridge-rs --filter telegram-worker run dev",
    "dev:zalo": "pnpm --parallel --stream --filter dlkn-socket-bridge-rs --filter zalo-worker run dev"
  }
}
